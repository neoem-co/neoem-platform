# ─── Typhoon (SCB 10X) ───────────────────────────────
TYPHOON_API_KEY=your-typhoon-api-key
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.5-30b-a3b-instruct

# ─── iApp Technology ─────────────────────────────────
IAPP_API_KEY=your-iapp-api-key
IAPP_OCR_URL=https://api.iapp.co.th/v3/store/ocr/document/ocr
IAPP_OCR_LAYOUT_URL=https://api.iapp.co.th/v3/store/ocr/document/layout
IAPP_THANOY_URL=https://api.iapp.co.th/v3/store/llm/thanoy-legal-ai

# ─── Vector Store ────────────────────────────────────
# "chromadb" for local dev, "pgvector" for production
VECTOR_STORE_PROVIDER=chromadb
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── Supabase (Production) ──────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-service-key
# SUPABASE_STORAGE_BUCKET=contracts

# ─── Application ─────────────────────────────────────
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
OCR_CHAR_THRESHOLD=50
