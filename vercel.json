{
    "rewrites": [
        {
            "source": "/api/ai/(.*)",
            "destination": "/ai_service/main.py"
        }
    ],
    "functions": {
        "ai_service/main.py": {
            "runtime": "vercel-python@0.1.1",
            "memory": 1024,
            "maxDuration": 60
        }
    }
}